[user]
  name = Ned
  email = 911877+nedn@users.noreply.github.com

[alias]
  aliases = "!git config --get-regexp '^alias\\.' | sed 's/^alias\\.//' | sed 's/ / = /' | sort"
  st = status
  ci = commit
  br = branch -a
  co = checkout
  df = diff
  lg = log -p
  tree = log --graph --decorate --pretty=oneline --abbrev-commit
  sticky = config credential.helper 'cache --timeout=10800'
  sq = !git reset --soft $(git rev-list --reverse origin/main..HEAD | head -1) && git commit --amend
  new = "!f() { git checkout -b \"$1\" --track origin/main; }; f"
  install-main-guard = "!f() { \
    hook=\"$(git rev-parse --git-path hooks/pre-commit)\"; \
    cat > \"$hook\" <<'EOF'\n#!/bin/sh\nbranch=$(git symbolic-ref --short HEAD 2>/dev/null)\nif [ \"$branch\" = \"main\" ] || [ \"$branch\" = \"master\" ]; then\n  echo \"Direct commits to $branch are blocked. Create a feature branch instead.\"\n  echo \"Use 'git commit --no-verify' to bypass.\"\n  exit 1\nfi\nEOF\n        chmod +x \"$hook\"; \
    echo \"Installed pre-commit hook at $hook\"; \
}; f"
  ned-private = "!f() { \
    git config user.name 'Ned'; \
    git config user.email '911877+nedn@users.noreply.github.com'; \
    n=\"$(git config user.name)\"; \
    e=\"$(git config user.email)\"; \
    FILTER_BRANCH_SQUELCH_WARNING=1 git filter-branch -f --env-filter \"export GIT_AUTHOR_NAME='$n'; export GIT_AUTHOR_EMAIL='$e'; export GIT_COMMITTER_NAME='$n'; export GIT_COMMITTER_EMAIL='$e'\" -- --all; \
    echo \"Rewrote all commits to $n <$e>. Now run: git push --force-with-lease\"; \
  }; f"
[color]
  status = auto
  branch = auto
  ui = auto
  diff = auto

[core]
  editor = vim

[merge]
  tool = meld
  conflictStyle = zdiff3

[branch]
  autosetuprebase = always

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[difftool]
    # Run the difftool immediately, don't ask 'are you sure' each time.
    prompt = false

[pager]
    # Use a pager if the difftool output is larger than one screenful,
    # consistent with the behaviour of `git diff`.
    difftool = true

[diff]
    external = difft
    # Set difftastic as the default difftool, so we don't need to specify
    # `-t difftastic` every time.
    tool = difftastic
